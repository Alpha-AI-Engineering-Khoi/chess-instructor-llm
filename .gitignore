# Secrets — never commit
.env
.env.*
*.key
secrets/
client_secret*.json
*apps.googleusercontent.com.json

# Large data artifacts
data/positions/*
data/transcripts/*
data/generated/*
data/dataset/*.jsonl
data/bank/*
data/curate/*
!data/curate/manifest.json
models/*
*.pgn
*.pgn.zst
*.pb.gz
*.csv
*.csv.zst

# Keep folder structure
!**/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
.ipynb_checkpoints/

# ===== Hardened exclusions (fresh public repo, appended) =====

# Env / secrets (belt-and-suspenders)
*.env
.env.local
.env.*.local
*.pem
*.p12
*.pfx
credentials.json
*credentials*.json
*.token
service-account*.json

# Node / Next.js (web app) — root-anchored so it matches web/ too
node_modules/
.next/
out/
build/
.vercel/
*.tsbuildinfo
.pnp
.pnp.*

# Model weights (belt-and-suspenders on top of models/*)
*.safetensors
*.gguf
*.npz
*.bin
*.pt
*.pth
*.onnx
models/adapters/
models/mlx/
models/maia/

# Python envs / tool caches
venv/
env/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Agent / local tooling state
.ralph/

# Local QA / verification screenshot artifacts
web/.qa-fix/
web/.tweaks-verify/

# OS
.DS_Store

# ===== Eval scratch + logs (keep `git status` readable) =====
# These are transient / re-derivable, NOT the committed benchmark+eval artifacts
# (data/benchmark_*/, data/eval/, data/showcase/ stay tracked — see README repo layout).

# All log files (run / gen / council / opt / judge logs) — never a source of truth
*.log

# Underscore-prefixed working files + model downloads for the grand / v4 / v5 evals
data/benchmark_grand/_*
data/benchmark_honest/_*
_v5dl
_v4dl

# Confounded / abandoned v5 run + one-off benchmark backups (not shipped)
data/benchmark_v5/
data/benchmark_honest_1p7_bak/

# Stage-4 re-eval: bulky, re-derivable inputs (built by scripts/stage4_*.py from
# the committed model outputs + scenarios_v6 + gitignored v6 labels). The committed
# evidence (stage4/*.jsonl model outputs, scores/verdict/rescore json, and the
# council raw rankings + aggregate) is enough to re-derive the verdict.
data/benchmark_gap803/stage4_eval_inputs.jsonl
data/benchmark_gap803/stage4_council/generations.jsonl
data/benchmark_gap803/stage4_council/scenarios.jsonl

# Always keep folder-structure placeholders
!**/.gitkeep
